# Required: this app mounts at /interview-coach under the dashboard zone.
NEXT_PUBLIC_BASE_PATH=/apps/interview-coach

# MeshAPI — same pattern as resume-builder
MESH_API_KEY=your_mesh_api_key_here
MESH_API_URL=https://api.meshapi.ai/v1

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/interview-coach?retryWrites=true&w=majority

# Resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=coach@yourdomain.com

# App — user-facing URL including the zone prefix. Used by email templates.
NEXT_PUBLIC_APP_URL=https://gids.meshapi.ai/apps/interview-coach
