# Supabase — powers POST /api/contact writes to the `leads` table.
# Find these in Supabase Dashboard → Project Settings → API:
#   SUPABASE_URL               = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY  = "service_role" secret  (NOT the anon key; this bypasses RLS)
SUPABASE_URL=<your-supabase-project-url>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Dashboard multi-zone deployment origins — set on Vercel for prod/preview only.
# In local dev these are ignored; rewrites fall back to http://localhost:<port> per the port table below.
# In prod a missing value is non-fatal: that sub-app's /apps/<name> card 404s until the env var is set.

NEXT_PUBLIC_CHAT_APP_DEPLOYMENT=https://gids-apps-chat-app.vercel.app
NEXT_PUBLIC_SALARY_DEPLOYMENT=https://gids-apps-guess-my-salary.vercel.app
NEXT_PUBLIC_RESUME_DEPLOYMENT=https://gids-apps-resume-builder.vercel.app
NEXT_PUBLIC_FLASHCARD_DEPLOYMENT=https://gids-apps-flashcard-engine.vercel.app
NEXT_PUBLIC_WILL_AI_DEPLOYMENT=https://gids-apps-will-ai-take-my-job.vercel.app
NEXT_PUBLIC_INTERVIEW_COACH_DEPLOYMENT=https://gids-apps-interview-coach.vercel.app
NEXT_PUBLIC_INVOICE_DEPLOYMENT=https://gids-apps-invoice-processor.vercel.app
NEXT_PUBLIC_SCREEN_SYNC_DEPLOYMENT=https://gids-apps-screen-sync.vercel.app

# Local dev port map (hardcoded in next.config.ts, listed here for reference):
#   dashboard            4000
#   chat-app             4001
#   guess-my-salary      4002
#   resume-builder       4003
#   flashcard-engine     4004
#   will-ai-take-my-job  4005
#   interview-coach      4006
#   invoice-processor    4007
#   screen-sync          4008
